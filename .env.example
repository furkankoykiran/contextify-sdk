# contextify-sdk sample environment.
# Most variables only become meaningful once the package's first feature
# release lands. Phase 0 leaves this as a placeholder.

# Contextify SaaS endpoint (leave blank for local dev once a real client ships).
CONTEXTIFY_API_BASE_URL=https://contextify.live

# Contextify API token. Required for any privileged call.
CONTEXTIFY_API_TOKEN=

# Optional Sentry DSN for this package's runtime.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
